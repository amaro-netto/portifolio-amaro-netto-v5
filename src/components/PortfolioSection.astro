---
import projectsData from '../data/projects.json';

const projects = [...projectsData].sort((a, b) => (Number(a.position) || 0) - (Number(b.position) || 0));
---

<section id="portfolio" class="bg-surface/10 scroll-mt-20 py-16 lg:py-24 border-t border-surface/30">
  <div class="container mx-auto px-4 lg:px-8 max-w-6xl">
    
    <div class="mb-12 md:mb-16">
      <h2 class="font-sans text-3xl md:text-4xl font-extrabold text-foreground mb-4 tracking-tight uppercase">
        Estudos de <span class="text-primary">Caso</span>
      </h2>
      <p class="text-foreground/70 text-base md:text-lg font-sans max-w-2xl leading-relaxed">
        Uma análise aprofundada de projetos recentes, demonstrando a aplicação prática de arquiteturas complexas, design moderno e engenharia de software voltada para resultados.
      </p>
    </div>

    <div id="portfolio-wrapper" class="relative w-full">
      
      {projects.map((project, index) => (
        <article class="portfolio-item hidden w-full animate-in fade-in duration-500" data-index={index}>
          
          <div class="flex flex-col mb-8">
            <div class="flex items-center gap-4 mb-4">
              <div class="flex gap-2">
                <button class="port-prev w-8 h-8 flex items-center justify-center rounded bg-background border border-surface/60 text-foreground/70 hover:text-primary hover:border-primary/50 transition-colors disabled:opacity-30 disabled:cursor-not-allowed">
                  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
                </button>
                <button class="port-next w-8 h-8 flex items-center justify-center rounded bg-background border border-surface/60 text-foreground/70 hover:text-primary hover:border-primary/50 transition-colors disabled:opacity-30 disabled:cursor-not-allowed">
                  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
                </button>
              </div>
              <div class="port-counter font-mono text-xs font-bold text-foreground/50 tracking-widest">
                </div>
            </div>

            <h3 class="font-sans text-2xl lg:text-3xl font-extrabold text-foreground mb-3">
              {project.title}
            </h3>
            
            <div class="flex items-center gap-4 text-xs font-medium text-foreground/60">
              <span class="flex items-center gap-1.5">
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
                {project.type}
              </span>
              <span class="flex items-center gap-1.5">
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
                {project.year}
              </span>
            </div>
          </div>

          <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 lg:gap-10">
            
            <div class="lg:col-span-7 flex flex-col gap-8">
              
              <div class="bg-surface/20 rounded-lg overflow-hidden border border-surface/50 aspect-video flex items-center justify-center">
                {project.image_card_url || project.image_modal_url ? (
                  <img 
                    src={project.image_card_url || project.image_modal_url} 
                    alt={`Screenshot do ${project.title}`} 
                    class="w-full h-full object-cover"
                    loading="lazy"
                  />
                ) : (
                  <span class="text-6xl font-bold text-surface/40">C</span>
                )}
              </div>

              <div class="space-y-6">
                {project.contexto && (
                  <div>
                    <h4 class="flex items-center gap-2 text-[11px] font-extrabold uppercase tracking-widest text-foreground/80 mb-2">
                      <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-primary"><polygon points="12 2 2 7 12 12 22 7 12 2"/><polyline points="2 17 12 22 22 17"/><polyline points="2 12 12 17 22 12"/></svg>
                      Contexto
                    </h4>
                    <p class="text-foreground/70 text-sm leading-relaxed">{project.contexto}</p>
                  </div>
                )}
                {project.abordagem && (
                  <div>
                    <h4 class="flex items-center gap-2 text-[11px] font-extrabold uppercase tracking-widest text-foreground/80 mb-2">
                      <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-primary"><circle cx="12" cy="12" r="10"/><path d="M12 2v20"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
                      Abordagem / Estratégia
                    </h4>
                    <p class="text-foreground/70 text-sm leading-relaxed">{project.abordagem}</p>
                  </div>
                )}
                {project.resultados && (
                  <div>
                    <h4 class="flex items-center gap-2 text-[11px] font-extrabold uppercase tracking-widest text-foreground/80 mb-2">
                      <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-primary"><polyline points="22 7 13.5 15.5 8.5 10.5 2 17"/><polyline points="16 7 22 7 22 13"/></svg>
                      Resultados & Impacto
                    </h4>
                    <p class="text-foreground/70 text-sm leading-relaxed">{project.resultados}</p>
                  </div>
                )}
              </div>
            </div>

            <div class="lg:col-span-5 flex flex-col gap-6">
              
              {project.tags && project.tags.length > 0 && (
                <div>
                  <h4 class="flex items-center gap-2 text-[11px] font-extrabold uppercase tracking-widest text-foreground/80 mb-3">
                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-primary"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg>
                    Tecnologias
                  </h4>
                  <div class="flex flex-wrap gap-2">
                    {project.tags.map((tag: string) => (
                      <span class="bg-surface/30 border border-surface/50 text-foreground/80 px-2.5 py-1 rounded-md text-xs font-semibold">
                        {tag}
                      </span>
                    ))}
                  </div>
                </div>
              )}

              {(project.objetivo || project.description) && (
                <div>
                  <h4 class="flex items-center gap-2 text-[11px] font-extrabold uppercase tracking-widest text-foreground/80 mb-2">
                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-primary"><circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="6"/><circle cx="12" cy="12" r="2"/></svg>
                    Objetivo
                  </h4>
                  <p class="text-foreground/70 text-sm leading-relaxed">
                    {project.objetivo || project.description}
                  </p>
                </div>
              )}

              {project.escopo && project.escopo.length > 0 && (
                <div>
                  <h4 class="flex items-center gap-2 text-[11px] font-extrabold uppercase tracking-widest text-foreground/80 mb-2">
                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-primary"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
                    Escopo & Complexidade
                  </h4>
                  <ul class="space-y-1.5">
                    {project.escopo.map((item: string) => (
                      <li class="flex items-start gap-2 text-sm text-foreground/70">
                        <span class="mt-1.5 w-1.5 h-1.5 rounded-full bg-primary shrink-0"></span>
                        <span class="leading-relaxed">{item}</span>
                      </li>
                    ))}
                  </ul>
                </div>
              )}

              <div class="flex flex-col sm:flex-row gap-3 pt-2">
                {project.project_url && (
                  <a href={project.project_url} target="_blank" rel="noopener noreferrer" class="inline-flex items-center justify-center px-4 py-2 border border-surface/80 text-foreground hover:bg-surface/20 transition-colors rounded-md text-xs font-bold">
                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="mr-2"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
                    Ver Projeto Online
                  </a>
                )}
                {project.code_url && (
                  <a href={project.code_url} target="_blank" rel="noopener noreferrer" class="inline-flex items-center justify-center px-4 py-2 border border-surface/80 text-foreground hover:bg-surface/20 transition-colors rounded-md text-xs font-bold">
                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="mr-2"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>
                    Repositório / Docs
                  </a>
                )}
              </div>

              <hr class="border-surface/40 my-2" />

              {project.papel && (
                <div>
                  <h4 class="flex items-center gap-2 text-[11px] font-extrabold uppercase tracking-widest text-foreground/80 mb-2">
                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-primary"><path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
                    Meu Papel
                  </h4>
                  <p class="text-foreground/70 text-sm leading-relaxed">{project.papel}</p>
                </div>
              )}

              {project.desafios && project.desafios.length > 0 && (
                <div>
                  <h4 class="flex items-center gap-2 text-[11px] font-extrabold uppercase tracking-widest text-foreground/80 mb-2">
                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-primary"><path d="m21.73 18-8-14a2 2 0 0 0-3.48 0l-8 14A2 2 0 0 0 4 21h16a2 2 0 0 0 1.73-3Z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
                    Principais Desafios
                  </h4>
                  <ul class="space-y-1.5">
                    {project.desafios.map((item: string) => (
                      <li class="flex items-start gap-2 text-sm text-foreground/70">
                        <span class="mt-1.5 w-1.5 h-1.5 rounded-full bg-primary shrink-0"></span>
                        <span class="leading-relaxed">{item}</span>
                      </li>
                    ))}
                  </ul>
                </div>
              )}

            </div>
          </div>
        </article>
      ))}
    </div>

  </div>
</section>

<script is:inline>
  document.addEventListener('DOMContentLoaded', () => {
    const items = document.querySelectorAll('.portfolio-item');
    const prevBtns = document.querySelectorAll('.port-prev');
    const nextBtns = document.querySelectorAll('.port-next');
    const counters = document.querySelectorAll('.port-counter');

    let currentIndex = 0;
    const totalItems = items.length;

    if (totalItems === 0) return;

    function updateView() {
      items.forEach((item, index) => {
        if (index === currentIndex) {
          item.classList.remove('hidden');
        } else {
          item.classList.add('hidden');
        }
      });

      // Atualiza botões
      prevBtns.forEach(btn => btn.disabled = currentIndex === 0);
      nextBtns.forEach(btn => btn.disabled = currentIndex === totalItems - 1);

      // Atualiza contador 01 / 02
      counters.forEach(counter => {
        counter.innerHTML = `${String(currentIndex + 1).padStart(2, '0')} <span class="opacity-40">/</span> ${String(totalItems).padStart(2, '0')}`;
      });
    }

    prevBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        if (currentIndex > 0) { currentIndex--; updateView(); }
      });
    });

    nextBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        if (currentIndex < totalItems - 1) { currentIndex++; updateView(); }
      });
    });

    updateView();
  });
</script>