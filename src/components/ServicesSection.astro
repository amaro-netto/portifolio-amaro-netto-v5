---
const services = [
  {
    title: "Desenvolvimento Sob Medida",
    description: "Sistemas web e arquiteturas backend robustas, focadas em escalabilidade, segurança e alta performance para resolver problemas de negócios complexos.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round"><path d="M16 18l6-6-6-6"/><path d="M8 6l-6 6 6 6"/><path d="M12 2v20"/></svg>`
  },
  {
    title: "UX/UI & Design Corporativo",
    description: "Criação de interfaces elegantes, funcionais e focadas na conversão. Transformo requisitos técnicos em experiências de usuário fluidas e profissionais.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20h9"/><path d="M16.5 3.5a2.12 2.12 0 0 1 3 3L7 19l-4 1 1-4Z"/></svg>`
  },
  {
    title: "Infraestrutura & DevOps",
    description: "Projetos de arquitetura em nuvem, conteinerização e automação de processos (CI/CD) para garantir que sua aplicação não sofra com indisponibilidades.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="8" rx="2" ry="2"/><rect x="2" y="14" width="20" height="8" rx="2" ry="2"/><line x1="6" y1="6" x2="6.01" y2="6"/><line x1="6" y1="18" x2="6.01" y2="18"/></svg>`
  },
  {
    title: "Consultoria Estratégica",
    description: "Diagnóstico técnico e governança de TI. Alinho a tecnologia aos objetivos do seu negócio, mitigando riscos e reduzindo custos operacionais.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>`
  }
];
---

<section id="servicos" class="bg-surface/10 scroll-mt-20 py-24 border-t border-surface/30">
  <div class="container mx-auto px-4">
    
    <div class="text-center max-w-3xl mx-auto mb-16">
      <h2 class="font-serif text-3xl md:text-5xl font-bold text-foreground mb-6 uppercase tracking-tight">
        Nossos <span class="text-primary italic lowercase">Serviços</span>
      </h2>
      <p class="text-foreground/70 text-lg leading-relaxed font-sans">
        Atuamos nos pilares fundamentais da tecnologia para entregar soluções de ponta a ponta, desde a infraestrutura do servidor até o clique final do seu cliente.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 lg:gap-10 max-w-6xl mx-auto">
      {services.map((service) => (
        <div class="group bg-background border border-surface/50 p-8 lg:p-12 transition-all duration-500 hover:border-primary/30 hover:shadow-xl hover:-translate-y-1 rounded-sm">
          
          <div class="mb-6 inline-flex items-center justify-center w-16 h-16 rounded-full bg-surface/30 text-primary group-hover:bg-primary group-hover:text-white transition-colors duration-500">
            <Fragment set:html={service.icon} />
          </div>
          
          <h3 class="font-serif text-2xl font-bold text-foreground mb-4 group-hover:text-primary transition-colors">
            {service.title}
          </h3>
          
          <p class="text-foreground/70 leading-relaxed font-sans text-justify">
            {service.description}
          </p>
          
        </div>
      ))}
    </div>

  </div>
</section>